  m_Script: {fileID: 11500000, guid: 6d6bb098678039d488c360927c77132c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Febucci.Examples.CurvesAndPlaybacksFormatter
  pressPlay: {fileID: 1750324269}
  headerTypewriter: {fileID: 520474329}
  curvesTypewriter: {fileID: 1463598792}
  playbacksTypewriter: {fileID: 335485984}
  headerTextToShow: Curves and Playbacks
  curvesTextToShow: '<waitfor=1><rainb>Curves</> allows you to change the animation''s
    interpolation


    Example:


    <bouncecurve>Bounce Curve</>

    <holdcurve>Hold
    Curve</>

    <linearcurve>Linear Curve</>

    <sinecurve>Sine Curve</>

    <stepcurve>Step
    Curve</>

    <wave>Square Curve</>'
  playbacksTextToShow: '<waitfor=1><rainb>Playbacks</> control the overall pacing,
    flow, and lifecycle of your animation


    Example:


    <repeatonce>Loop Once</>

    <loopntimes>Loop
    3 times then stop</>

    <repeatplayback>Stop 2s between cycles</>

    <noease>No
    easing between cycles</>'
